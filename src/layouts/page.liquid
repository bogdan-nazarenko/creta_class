<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{ title }}</title>
        <link rel="icon" href="favicon.png" type="image/png">
        {%- if styles %}
            {%- for style in styles %}
                <link rel="stylesheet" href="{{ style }}">
            {%- endfor %}
        {%- endif %}
    </head>
    <body class="page">
        {{ content }}
        {%- if scripts %}
            {%- for script in scripts -%}
                <script
                    src="{{ script.src }}"
                    {%- if script.type %}
                        type="{{ script.type }}"
                    {%- endif %}
                ></script>
            {%- endfor %}
        {%- endif %}
    </body>
</html>
